# Copy to `.env` and fill in. NEVER commit your real .env.
# Private keys are NOT stored here — use encrypted keystore accounts (see Makefile / README).

SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Keystore account names created via `cast wallet import` (see Makefile).
# These are just labels, not secrets.
ANVIL_ACCOUNT=anvil-deployer
SEPOLIA_ACCOUNT=sepolia-deployer
MAINNET_ACCOUNT=mainnet-deployer
